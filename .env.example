# Supabase project — get these from Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-public-key>

# Server-only (used by /server/api routes via serverSupabaseServiceRole).
# NEVER expose to the client.
SUPABASE_SERVICE_KEY=<service-role-key>

# Supabase CLI auth (migrations, type gen). Not used by the app runtime.
SUPABASE_PAT=<personal-access-token>
